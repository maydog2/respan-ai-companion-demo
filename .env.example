# Copy this file to ".env" in the repo root and set local secrets (never commit ".env").
#
# Neon (recommended: use the "pooled" connection string from the dashboard).
# Keep sslmode=require. If you see TLS / channel-binding errors on Windows, try
# removing "&channel_binding=require" from the query string.
#
# DB_URL=postgresql://USER:PASSWORD@ep-....neon.tech/neondb?sslmode=require

# Required for login/session token signing.
# AUTH_TOKEN_SECRET=replace-with-a-long-random-string

# LLM provider (Respan Gateway is OpenAI-compatible).
# RESPAN_API_KEY=resp_...
# RESPAN_MODEL=gpt-4o-mini
#
# Optional direct OpenAI-compatible fallback:
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o
